# ─── Step Cook — variables d'environnement ───
# Copiez ce fichier en `.env.local` et remplissez ce dont vous avez besoin.
# TOUTES ces intégrations sont OPTIONNELLES : le mode manuel (coller une
# recette → pas-à-pas) fonctionne sans aucune configuration.

# ── Mealie (import de recettes depuis une instance Mealie auto-hébergée) ──
MEALIE_BASE_URL=
# Même URL, exposée au client (bouton « voir sur Mealie ») :
NEXT_PUBLIC_MEALIE_BASE_URL=
MEALIE_API_TOKEN=
# Cookie Cloudflare Access si Mealie est derrière Cloudflare Zero Trust
# (CF_AppSession + CF_Authorization) — expire régulièrement :
MEALIE_CF_COOKIE=

# ── Google Gemini (génération / adaptation de recettes par IA) ──
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# ── Firebase Firestore (sauvegarde des recettes générées par IA) ──
# Au choix : chemin vers le fichier service account…
FIREBASE_SERVICE_ACCOUNT_PATH=./private/firebase-service-account.json
# …ou le JSON du service account directement (pratique en déploiement) :
FIREBASE_SERVICE_ACCOUNT_JSON=
